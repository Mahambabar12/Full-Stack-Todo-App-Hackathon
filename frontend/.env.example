# Task T-240: Frontend Environment Variables (Phase 1 Setup)
# Copy this to .env.local and fill in actual values for local development

# Better Auth Server URL (where /api/auth routes are hosted)
# Points to the Next.js frontend itself (since Better Auth runs in the same app)
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# Backend FastAPI URL
# Points to the backend server that provides todo CRUD endpoints
# Used for: GET /api/todos, POST /api/todos, etc.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database URL for Better Auth (if using local database)
# Format: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/evo_todo

# Better Auth Secret (generate with: openssl rand -base64 32)
# Used for signing and encrypting sensitive data
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Node environment
NODE_ENV=development

# Optional: API timeout (in ms) - uncomment to override default
# API_TIMEOUT=30000
