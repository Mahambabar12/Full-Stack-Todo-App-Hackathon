# Task T-221/T-222/T-223: Better Auth + Neon Configuration
# Copy to .env and configure for your environment

# Database Configuration (Neon Serverless PostgreSQL)
# For local development, use Docker PostgreSQL
# For production, get connection string from Neon console
DATABASE_URL=postgresql://evo_todo_user:evo_todo_password@localhost:5432/evo_todo

# Better Auth Configuration (T-221)
# Get these values from your Better Auth service setup
BETTER_AUTH_SECRET=your-better-auth-secret-key-change-in-production
BETTER_AUTH_API_URL=https://api.betterauth.io

# JWT Configuration (from Better Auth JWT plugin)
# Better Auth handles token creation; FastAPI validates JWTs
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Environment
ENVIRONMENT=development
DEBUG=True
