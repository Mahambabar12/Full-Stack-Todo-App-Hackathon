# Task T-202: Backend Environment Variables
# Copy to .env and configure for your environment

# Database Configuration
DATABASE_URL=postgresql://evo_todo_user:evo_todo_password@localhost:5432/evo_todo

# JWT Configuration
JWT_SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Environment
ENVIRONMENT=development
DEBUG=True
